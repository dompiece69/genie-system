# ---- Database ----
# MySQL/TiDB connection string
DATABASE_URL=mysql://user:password@host:3306/genie_system

# ---- Authentication ----
# Secret key for JWT session cookies (generate a strong random string)
JWT_SECRET=your-very-strong-random-secret-here
# OAuth server URL (Manus platform)
OAUTH_SERVER_URL=https://oauth.manus.app
# OpenID of the owner account (will be granted admin role automatically)
OWNER_OPEN_ID=

# ---- AI / Scanning ----
# Perplexity Sonar API key for real-time internet scanning
# Get yours at https://www.perplexity.ai/settings/api
SONAR_API_KEY=pplx-xxxx

# ---- Stripe Payments ----
# Stripe secret key (starts with sk_live_ for production, sk_test_ for testing)
# Get yours at https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_xxxx
# Stripe webhook signing secret — create a webhook at https://dashboard.stripe.com/webhooks
# pointing to https://yourdomain.com/api/stripe/webhook with the checkout.session.completed event
STRIPE_WEBHOOK_SECRET=whsec_xxxx

# ---- App ----
# Your public-facing app URL (no trailing slash), used for Stripe redirect URLs
APP_BASE_URL=https://yourdomain.com

# ---- Storage (optional, for file delivery) ----
# Built-in Manus storage proxy credentials
BUILT_IN_FORGE_API_URL=
BUILT_IN_FORGE_API_KEY=

# ---- App ID ----
VITE_APP_ID=
